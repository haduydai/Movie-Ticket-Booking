<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xmlns="https://jakarta.ee/xml/ns/jakartaee"
         xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee https://jakarta.ee/xml/ns/jakartaee/web-app_6_0.xsd"
         id="WebApp_ID" version="6.0">
    <display-name>MovieTicketBooking</display-name>

    <!-- Đăng ký DbContextListener để tự động chạy khi khởi động/tắt ứng dụng -->
    <listener>
        <listener-class>utils.DbContextListener</listener-class>
    </listener>
    <!-- Đăng ký TransactionFilter -->
    <filter>
        <filter-name>TransactionFilter</filter-name>
        <filter-class>utils.TransactionFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>TransactionFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>

    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>
</web-app>